# Database Connection (Neon PostgreSQL or any other PostgreSQL provider)
DATABASE_URL="postgresql://user:password@endpoint-pooler.postgres.neon.tech/nextdoorclinic?sslmode=require"

# Auth.js Authentication Configuration
# Run `openssl rand -base64 33` to generate a secure secret keys
AUTH_SECRET="super-secret-auth-key-at-least-32-characters"
NEXTAUTH_URL="https://booking.nextdoorclinic.co.uk"

# App public domain URL (Vercel deployment)
NEXT_PUBLIC_APP_URL="https://booking.nextdoorclinic.co.uk"
NODE_ENV="production"

# Resend API Key for responsive email template dispatches
RESEND_API_KEY="re_abc123XyZ789"

# Cloudflare R2 Credentials for dynamic logo/asset branding uploads
R2_ACCOUNT_ID="your_cloudflare_account_id_hex"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="nextdoorclinic-branding-bucket"
R2_PUBLIC_DOMAIN="branding-cdn.nextdoorclinic.co.uk"
